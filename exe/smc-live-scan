  ai: true
}.freeze

def parse_options
  options = OPTIONS.dup
  OptionParser.new do |opts|
    opts.banner = "Usage: smc-live-scan [options]"
    opts.on("-p", "--pair PAIR", "Trading pair") { |v| options[:pair] = v }
    opts.on("-i", "--interval INTERVAL", "1m, 5m, 15m, 1h") { |v| options[:interval] = v }
    opts.on("-l", "--limit LIMIT", Integer, "Candle history") { |v| options[:limit] = v }
    opts.on("-b", "--playbook ID", "Focus playbook") { |v| options[:playbook] = v }
    opts.on("-r", "--min-rr RR", Float, "Min R:R filter") { |v| options[:min_rr] = v }
    opts.on("-s", "--poll-seconds SEC", Integer, "Poll interval") { |v| options[:poll_seconds] = v }
    opts.on("-n", "--max-polls N", Integer, "Max poll cycles") { |v| options[:max_polls] = v }
    opts.on("-f", "--formation MIN", Integer, "Min formation % to show (default: 5)") { |v| options[:formation_min] = v }
    opts.on("-q", "--quiet", "Only show forming/ready playbooks") { options[:verbose] = false }
    opts.on("--any-playbook", "Evaluate ALL playbooks — fire whichever signals first (default)") { options[:any_playbook] = true }
    opts.on("-b", "--playbook ID", "Focus playbook (overrides --any-playbook)") { |v| options[:playbook] = v; options[:any_playbook] = false }
    opts.on("--dry-run", "Print signals only, do not execute") { options[:dry_run] = true }
    opts.on("--[no-]ai", "Enable/disable AI insights using ollama-client (default: true)") { |v| options[:ai] = v }
    opts.on("-h", "--help", "Show help") { puts opts; exit }
  end.parse!
  options
end

# --- Colors ---
def pastel
  @pastel ||= Pastel.new
end

STATUS_STYLES = {
  executing: ->(t) { pastel.on_bright_green.black(t) },
  ready:     ->(t) { pastel.bright_green(t) },
  forming:   ->(t) { pastel.yellow(t) },
  warming_up:->(t) { pastel.dim(t) },
  dormant:   ->(t) { pastel.dim(t) },
}.freeze

# --- Data Fetchers ---
module LiveDataFetcher
  def self.fetch_coindcx(pair:, interval:, limit:, spinner: nil)
    raise "CoinDCX client not available" unless defined?(CoinDCX)

    CoinDCX.configure do |config|
      config.api_key = ENV.fetch("COINDCX_API_KEY", "dummy_key")
      config.api_secret = ENV.fetch("COINDCX_API_SECRET", "dummy_secret")
    end

    spinner&.update(title: "Fetching #{pair} #{interval}…") if spinner
    raw = CoinDCX.client.public.market_data.list_candles(
      pair: pair, interval: interval, limit: limit
    )
    return [] if raw.nil? || raw.empty?

    candles = raw.reverse.map do |c|
      SMC::Candle.new(
        time: Time.at(c["time"] / 1000).utc,
        open: c["open"].to_f,
        high: c["high"].to_f,
        low: c["low"].to_f,
        close: c["close"].to_f,
        volume: c["volume"].to_f
      )
    end
    spinner&.success if spinner
    candles
  end
end

# --- Pipeline ---
def build_and_warm(candles, spinner: nil)
  pd = SMC::PivotDetector.new(left_bars: 4, right_bars: 4)
  ms = SMC::MarketStructure.new
  ls = SMC::LiquiditySweep.new(tolerance_pct: 0.0015)
  obd = SMC::OrderBlockDetector.new

  spinner&.update(title: "Warming up pipeline…")
  start_idx = [pd.left_bars + pd.right_bars + 15, 30].max

  (start_idx..(candles.size - 1)).each do |i|
    swings = pd.detect_swings(candles[0..i])
    ms.update(swings, candles[i], i)
    ls.update_equal_levels(swings)
    ls.detect_sweeps(swings, candles[i], i)
    ms.bos_events.last&.then { |e| obd.check_for_new_ob(e, candles, i) if e[:index] == i }
    ms.choch_events.last&.then { |e| obd.check_for_new_ob(e, candles, i) if e[:index] == i }
    obd.update_mitigations(candles[i], i)
  end
  spinner&.success if spinner
  { pivot_detector: pd, market_structure: ms, liquidity_sweep: ls, ob_detector: obd }
end

def process_new_candle(candles, pipeline, idx)
  pd = pipeline[:pivot_detector]
  ms = pipeline[:market_structure]
  ls = pipeline[:liquidity_sweep]
  obd = pipeline[:ob_detector]
  swings = pd.detect_swings(candles[0..idx])
  ms.update(swings, candles[idx], idx)
  ls.update_equal_levels(swings)
  ls.detect_sweeps(swings, candles[idx], idx)
  ms.bos_events.last&.then { |e| obd.check_for_new_ob(e, candles, idx) if e[:index] == idx }
  ms.choch_events.last&.then { |e| obd.check_for_new_ob(e, candles, idx) if e[:index] == idx }
  obd.update_mitigations(candles[idx], idx)
end

# --- Tables ---
def build_progress_bar(pct, width: 16)
  filled = (pct / 100.0 * width).round.clamp(0, width)
  empty = width - filled
  █ = "█"
  ░ = "░"
  # color scale
  bar = if pct >= 85 then pastel.bright_green(█ * filled)
        elsif pct >= 50 then pastel.yellow(█ * filled)
        elsif pct >= 25 then pastel.cyan(█ * filled)
        else pastel.red(█ * filled)
        end
  bar + pastel.dim(░ * empty)
end

def print_header(options)
  font = TTY::Font.new(:standard)
  puts pastel.bright_blue(font.write("SMC"))
  puts pastel.cyan("  Live Formation Scanner")
  puts ""
  mode = if options[:any_playbook]
           "ANY playbook (fire first)"
         elsif options[:playbook]
           "Focus: #{options[:playbook]}"
         else
           "ANY playbook (fire first)"
         end
  puts pastel.dim("  Pair: #{options[:pair]} | Interval: #{options[:interval]} | Mode: #{mode} | Min RR: 1:#{options[:min_rr]}")
  puts ""
end

def print_banner(text, color: :bright_blue)
  puts pastel.public_send(color, "═" * 60)
  puts pastel.public_send(color, "  #{text}")
  puts pastel.public_send(color, "═" * 60)
end

def print_signal_box(signal, triggered_playbook = nil)
  puts ""
  if triggered_playbook.is_a?(SMC::Playbook::FormationReport)
    puts pastel.on_bright_green.black("  🔥  #{triggered_playbook.playbook.id} #{triggered_playbook.direction.to_s.upcase} — SIGNAL FIRED! 🔥")
    puts pastel.bright_white("  #{triggered_playbook.playbook.name}")
  else
    puts pastel.on_bright_green.black("  🔥  SIGNAL DETECTED  🔥")
    puts pastel.bright_white("  Playbook : #{signal[:playbook]}")
  end
  puts ""
  puts pastel.bright_white("  Direction: #{signal[:type].to_s.upcase}")
  puts ""
  puts pastel.green("  Entry  : #{signal[:entry]&.round(2)}")
  puts pastel.red("  SL     : #{signal[:sl]&.round(2)}")
  puts pastel.yellow("  TP1    : #{signal[:tp1]&.round(2)}")
  puts pastel.yellow("  TP2    : #{signal[:tp2]&.round(2)}")
  puts pastel.bright_yellow("  TP3    : #{signal[:tp3]&.round(2)}")
  puts ""
  puts pastel.cyan("  R:R    : 1:#{signal[:risk_reward]}")
  passed_rules = signal[:rules_checked]&.select { |_, v| v }&.keys
  puts pastel.dim("  Rules  : #{passed_rules&.first(6)&.join(', ')}#{passed_rules&.size.to_i > 6 ? '…' : ''}")
  puts ""
end

def print_formation_table(reports, verbose: true)
  return if reports.empty?

  rows = reports.map do |r|
    bar = build_progress_bar(r.formation_pct)
    status_icon = case r.status
                  when :executing then "🔥"
                  when :ready     then "✅"
                  when :forming   then "⚡"
                  when :warming_up then "🌡️"
                  else "•"
                  end

    pb_name = r.playbook.name.length > 24 ? "#{r.playbook.name[0..22]}…" : r.playbook.name

    [
      "#{status_icon} #{r.direction.to_s.upcase}",
      pb_name,
      STATUS_STYLES[r.status]&.call(r.status.to_s.upcase) || r.status.to_s.upcase,
      "#{r.formation_pct}%",
      bar
    ]
  end

  table = TTY::Table.new(header: ["Dir", "Playbook", "Status", "Formed", "Progress"], rows: rows)
  puts table.render(:unicode, padding: [0, 1])

  if verbose
    reports.each do |r|
      next unless r.next_trigger

      puts "  #{pastel.cyan('▸')} #{pastel.bright_white(r.playbook.id)} | #{pastel.yellow(r.next_trigger[:description])}"

      if r.projected_levels && r.projected_levels[:entry]
        lv = r.projected_levels
        proj = "📐 ENTRY #{lv[:entry]} | SL #{lv[:sl] || '-'} | TP3 #{lv[:tp3] || '-'} | R:R 1:#{lv[:rr] || '-'}"
        puts "     #{pastel.dim(proj)}"
      end
    end
  end
end

def ai_client
  return nil unless defined?(Ollama::Client)

  @ai_client ||= begin
    config = Ollama::Config.new
    config.base_url = ENV['OLLAMA_BASE_URL'] if ENV['OLLAMA_BASE_URL']
    config.model = ENV['OLLAMA_AGENT_MODEL'] || ENV['OLLAMA_MODEL'] || 'llama3.2:3b'
    config.api_key = ENV['OLLAMA_API_KEY'] if ENV['OLLAMA_API_KEY']
    Ollama::Client.new(config: config)
  rescue => e
    nil
  end
end

def fetch_ai_insights(options, candles, pipeline, reports, signal = nil)
  client = ai_client
  return nil unless client

  ms = pipeline[:market_structure]

  active_playbooks_desc = reports.select { |r| r.formation_pct >= 50 }.map do |r|
    "- #{r.playbook.id} (#{r.playbook.name}): #{r.direction.to_s.upcase} | #{r.formation_pct}% formed | Status: #{r.status} | Next: #{r.next_trigger&.dig(:description)}"
  end.join("\n")

  signal_desc = if signal
    "ACTIVE SIGNAL DETECTED:\n" \
    "- Playbook: #{signal[:playbook]}\n" \
    "- Direction: #{signal[:type].to_s.upcase}\n" \
    "- Entry: #{signal[:entry]}\n" \
    "- Stop Loss: #{signal[:sl]}\n" \
    "- Take Profit (TP3): #{signal[:tp3]}\n" \
    "- Risk/Reward Ratio: 1:#{signal[:risk_reward]}"
  else
    "No active entry signals triggered yet."
  end

  prompt = <<~PROMPT
    You are an AI Trading Assistant specializing in Smart Money Concepts (SMC) and ICT institutional trading playbook rules.
    Analyze the current live market state and provide a concise, high-impact "AI Market Insight" for the trader.

    [Market State]
    - Pair: #{options[:pair]}
    - Interval: #{options[:interval]}
    - Latest Close: #{candles.last.close}
    - Current Trend: #{ms.trend} (BOS: #{ms.bos_events.size}, CHoCH: #{ms.choch_events.size})

    [Forming Playbooks (>= 50%)]
    #{active_playbooks_desc.empty? ? "None" : active_playbooks_desc}

    [Trade Signals]
    #{signal_desc}

    Instructions:
    - Provide 3-4 bullet points of crisp, actionable insights.
    - Evaluate which playbook is most promising or if the current signal is high-quality.
    - Note any potential traps (e.g., lack of liquidity sweeps, aggressive CHoCH without displacement, bad risk-to-reward ratio).
    - Keep the output format simple: only bullet points (using standard '-' prefix), no title, no markdown blocks, max 100 words.
  PROMPT

  begin
    model = ENV['OLLAMA_AGENT_MODEL'] || ENV['OLLAMA_MODEL'] || 'llama3.2:3b'
    response = client.generate(prompt: prompt, model: model)
    response.to_s.strip
  rescue => e
    "AI Insights Error: #{e.message}"
  end
end

def print_ai_insights(insights)
  return if insights.nil? || insights.empty?

  puts ""
  box = TTY::Box.frame(
    width: 60,
    align: :left,
    padding: 1,
    title: { top_left: " 🤖 AI INSIGHTS " },
    style: {
      border: {
        fg: :cyan
      }
    }
  ) { pastel.cyan(insights) }
  puts box
end

# --- Main ---

def main
  options = parse_options

  print_header(options)

  unless defined?(CoinDCX)
    puts pastel.red("ERROR: CoinDCX client not loaded. Cannot fetch live data.")
    exit 1
  end

  spinner = TTY::Spinner.new("[:spinner] :title", format: :arrow, hide_cursor: true)
  spinner.auto_spin

  spinner.update(title: "Fetching #{options[:limit]} candles for #{options[:pair]}…")
  candles = LiveDataFetcher.fetch_coindcx(
    pair: options[:pair], interval: options[:interval], limit: options[:limit], spinner: spinner
  )

  if candles.empty?
    spinner.error("No candles fetched")
    puts pastel.red("ERROR: Check API credentials and pair name.")
    exit 1
  end
  spinner.success("Loaded #{candles.size} candles")

  pipeline = build_and_warm(candles, spinner: spinner)
  ms = pipeline[:market_structure]

  puts "  Bars: #{candles.size} | Swings: #{ms.swings.size} | BOS: #{ms.bos_events.size} | CHoCH: #{ms.choch_events.size} | Trend: #{ms.trend}"
  puts ""

  last_fetched_time = candles.last.time
  poll_count = 0

  loop do
    sleep(options[:poll_seconds])
    poll_count += 1

    puts ""
    print_banner("POLL #{poll_count} — #{Time.now.utc.strftime('%H:%M:%S UTC')}")

    begin
      fresh = CoinDCX.client.public.market_data.list_candles(
        pair: options[:pair], interval: options[:interval], limit: 5
      )
    rescue StandardError => e
      puts pastel.red("  Fetch error: #{e.message}")
      next
    end

    new_candles = fresh.reverse.select { |c| Time.at(c["time"] / 1000).utc > last_fetched_time }

    if new_candles.empty?
      puts pastel.dim("  No new candles yet.")
      next
    end

    new_candles.each do |raw|
      c = SMC::Candle.new(
        time: Time.at(raw["time"] / 1000).utc,
        open: raw["open"].to_f, high: raw["high"].to_f,
        low: raw["low"].to_f, close: raw["close"].to_f,
        volume: raw["volume"].to_f
      )
      candles << c
      last_fetched_time = c.time
      process_new_candle(candles, pipeline, candles.size - 1)
    end

    ms = pipeline[:market_structure]
    puts "  New: #{new_candles.size} bar(s) | Latest close: #{pastel.yellow(candles.last.close.round(2).to_s)} | Trend: #{ms.trend}"

    # Formation analysis
    fa = SMC::Playbook::FormationAnalyzer.new(
      candles: candles, current_idx: candles.size - 1,
      pivot_detector: pipeline[:pivot_detector],
      market_structure: pipeline[:market_structure],
      liquidity_sweep: pipeline[:liquidity_sweep],
      ob_detector: pipeline[:ob_detector]
    )
    reports = fa.analyze_all(min_formation: options[:formation_min] / 100.0)

    puts ""
    print_banner("FORMATION TRACKER", color: :bright_cyan)
    print_formation_table(reports, verbose: options[:verbose])

    # Evaluate strategies — any-playbook mode fires on whichever signals first
    signal = nil
    triggered_playbook = nil

    if options[:any_playbook] || options[:playbook].nil?
      ready_reports = reports.select { |r| r.status == :ready || r.status == :executing }
      ready_reports.each do |r|
        pb = r.playbook
        next unless pb

        strat = if pb.strategy_class
                  pb.strategy_class.new
                else
                  SMC::Strategy::PlaybookStrategyAdapter.new(
                    playbook_or_id: pb.id, min_risk_reward: options[:min_rr]
                  )
                end

        sig = strat.evaluate(
          candles, candles.size - 1,
          pipeline[:pivot_detector], pipeline[:market_structure],
          pipeline[:liquidity_sweep], pipeline[:ob_detector]
        )

        if sig
          signal = sig
          triggered_playbook = r
          break  # fire on first valid signal
        end
      end
    else
      # Focus mode: only evaluate the chosen playbook
      pb = SMC::Playbook::PlaybookRegistry.default.find(options[:playbook])
      if pb
        strategy = if pb.strategy_class
                     pb.strategy_class.new
                   else
                     SMC::Strategy::PlaybookStrategyAdapter.new(
                       playbook_or_id: options[:playbook], min_risk_reward: options[:min_rr]
                     )
                   end
        signal = strategy.evaluate(
          candles, candles.size - 1,
          pipeline[:pivot_detector], pipeline[:market_structure],
          pipeline[:liquidity_sweep], pipeline[:ob_detector]
        )
        triggered_playbook = options[:playbook] if signal
      end
    end

    if signal
      print_signal_box(signal, triggered_playbook)
      puts pastel.bright_white("  DRY RUN — no order placed.") if options[:dry_run]
    elsif reports.any? { |r| r.status == :forming || r.status == :ready }
      forming = reports.select { |r| r.status == :forming || r.status == :ready }
      puts ""
      puts pastel.yellow("  ⚡ #{forming.size} playbook(s) ≥ 50% formed — watching for execution…")
      forming.each do |r|
        puts pastel.dim("     #{r.playbook.id} #{r.direction.to_s.upcase}: #{r.formation_pct.round(1)}% | Next: #{r.next_trigger&.dig(:description)}")
      end
    elsif reports.any? { |r| r.status == :warming_up }
      puts ""
      puts pastel.dim("  🌡️ #{reports.select { |r| r.status == :warming_up }.size} playbook(s) warming up.")
    else
      puts ""
      puts pastel.red("  No formations above #{options[:formation_min]}% threshold.")
    end

    if options[:ai]
      insights = fetch_ai_insights(options, candles, pipeline, reports, signal)
      print_ai_insights(insights)
    end

    break if poll_count >= options[:max_polls]
  end

  puts ""
  puts pastel.dim("[EXIT] Max polls reached. Shutting down.")
end

main if __FILE__ == $0
